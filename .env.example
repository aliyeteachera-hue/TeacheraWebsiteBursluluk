VITE_SITE_URL=https://teachera.com.tr

# Tag Manager / Analytics
# GTM container currently provided by user:
# VITE_GTM_ID=GTM-K9JW67GT
#
# Optional references used during GTM tag setup:
# VITE_GA4_MEASUREMENT_ID=G-LZQ3PLT0ER
# VITE_GOOGLE_ADS_ID=AW-10934875583
# VITE_META_PIXEL_ID=123456789012345

# Frontend -> backend proxy endpoint (defaults to /api/forms)
# VITE_FORMS_PROXY_ENDPOINT=/api/forms

# Cloudflare Turnstile (recommended for bot protection)
# VITE_TURNSTILE_SITE_KEY=your_public_site_key
# TURNSTILE_SECRET_KEY=your_private_secret_key

# Backend proxy -> upstream form provider
# FORMS_UPSTREAM_TEMPLATE=https://formsubmit.co/ajax/{to}
# Optional fixed endpoint:
# FORMS_UPSTREAM=https://example.com/api/forms

# Optional CORS allowlist (comma separated)
# FORMS_ALLOWED_ORIGINS=https://teachera.com.tr,https://www.teachera.com.tr

# --- Exam backend core ---
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# POSTGRES_URL=postgres://user:pass@host:5432/dbname
# PG_POOL_MAX=30
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS=5000
# PG_SSL_MODE=strict
# Allowed values: strict | relaxed | disable
# Production default is strict TLS verification.
# relaxed/disable are only allowed in non-production (local/dev).
# DEFAULT_CAMPAIGN_CODE=2026_BURSLULUK
# EXAM_SESSION_TTL_MINUTES=180
# NOTIFICATION_RETRY_LIMIT=5
#
# --- Redis (session, rate-limit, short-lived counters/locks) ---
# REDIS_URL=redis://default:password@host:6379
# REDIS_KEY_PREFIX=teachera
# REDIS_CONNECT_TIMEOUT_MS=3000
# REDIS_OPERATION_TIMEOUT_MS=1200
# REDIS_RECONNECT_DELAY_MS=250
# REDIS_CONNECT_MAX_RETRIES=1
#
# RL_EXAM_START_IP_LIMIT=25
# RL_EXAM_START_IP_WINDOW_SECONDS=60
# RL_EXAM_START_PHONE_LIMIT=6
# RL_EXAM_START_PHONE_WINDOW_SECONDS=600
#
# RL_EXAM_ANSWER_IP_LIMIT=300
# RL_EXAM_ANSWER_IP_WINDOW_SECONDS=60
# RL_EXAM_ANSWER_ATTEMPT_LIMIT=200
# RL_EXAM_ANSWER_ATTEMPT_WINDOW_SECONDS=60
# EXAM_ANSWER_BURST_WINDOW_SECONDS=15
# EXAM_ANSWER_BURST_MAX=45
#
# RL_EXAM_SUBMIT_IP_LIMIT=40
# RL_EXAM_SUBMIT_IP_WINDOW_SECONDS=60
# RL_EXAM_SUBMIT_ATTEMPT_LIMIT=8
# RL_EXAM_SUBMIT_ATTEMPT_WINDOW_SECONDS=300
# EXAM_SUBMIT_LOCK_TTL_SECONDS=20
#
# RL_EXAM_RESULT_IP_LIMIT=90
# RL_EXAM_RESULT_IP_WINDOW_SECONDS=60
# RL_EXAM_RESULT_ATTEMPT_LIMIT=30
# RL_EXAM_RESULT_ATTEMPT_WINDOW_SECONDS=60
# RL_EXAM_RESULT_PANEL_LIMIT=500
# RL_EXAM_RESULT_PANEL_WINDOW_SECONDS=60

# --- Anti-abuse hardening (P0-7) ---
# RL_PANEL_LOGIN_IP_LIMIT=20
# RL_PANEL_LOGIN_IP_WINDOW_SECONDS=60
# RL_PANEL_LOGIN_EMAIL_LIMIT=12
# RL_PANEL_LOGIN_EMAIL_WINDOW_SECONDS=300
# RL_PANEL_PASSWORD_RESET_USER_LIMIT=6
# RL_PANEL_PASSWORD_RESET_USER_WINDOW_SECONDS=900
#
# BRUTE_PANEL_LOGIN_IP_THRESHOLD=12
# BRUTE_PANEL_LOGIN_IP_WINDOW_SECONDS=600
# BRUTE_PANEL_LOGIN_IP_LOCK_SECONDS=900
# BRUTE_PANEL_LOGIN_EMAIL_THRESHOLD=8
# BRUTE_PANEL_LOGIN_EMAIL_WINDOW_SECONDS=900
# BRUTE_PANEL_LOGIN_EMAIL_LOCK_SECONDS=1800
#
# BRUTE_EXAM_SESSION_IP_THRESHOLD=30
# BRUTE_EXAM_SESSION_IP_WINDOW_SECONDS=300
# BRUTE_EXAM_SESSION_IP_LOCK_SECONDS=600
# BRUTE_EXAM_SESSION_TOKEN_THRESHOLD=12
# BRUTE_EXAM_SESSION_TOKEN_WINDOW_SECONDS=300
# BRUTE_EXAM_SESSION_TOKEN_LOCK_SECONDS=600
#
# RL_FORMS_IP_LIMIT=20
# RL_FORMS_IP_WINDOW_SECONDS=60
# RL_FORMS_CONTACT_LIMIT=10
# RL_FORMS_CONTACT_WINDOW_SECONDS=600
# BRUTE_FORMS_IP_THRESHOLD=10
# BRUTE_FORMS_IP_WINDOW_SECONDS=600
# BRUTE_FORMS_IP_LOCK_SECONDS=900
# BRUTE_FORMS_CONTACT_THRESHOLD=6
# BRUTE_FORMS_CONTACT_WINDOW_SECONDS=900
# BRUTE_FORMS_CONTACT_LOCK_SECONDS=1800

# --- Panel auth (server-signed session token + MFA) ---
# PANEL_SESSION_SECRET=replace_with_a_long_random_secret
# PANEL_SESSION_TTL_MINUTES=480
# PANEL_SESSION_COOKIE_NAME=teachera_panel_session
# PANEL_TOTP_WINDOW_STEPS=1
# PANEL_PASSWORD_MIN_LENGTH=10
#
# --- P0-8 PII encryption + audit logging ---
# PII_CRYPTO_STRICT=true
# PII_KMS_REGION=eu-north-1
# PII_KMS_KEY_ID=arn:aws:kms:eu-north-1:123456789012:key/xxxx-xxxx-xxxx
# PII_KMS_ENCRYPTED_DATA_KEY_B64=base64_of_kms_encrypted_32_byte_data_key
# PII_LOOKUP_HMAC_KEY=long_random_hmac_key_for_lookup_hashes

# --- Frontend exam API endpoint ---
# VITE_EXAM_API_BASE=

# --- Notification worker / provider webhooks ---
# NOTIFICATION_WORKER_SECRET=change_me
# CRON_SECRET=change_me
# NOTIFICATION_PROVIDER_WEBHOOK_SECRET=change_me
# NOTIFICATION_PROVIDER_WEBHOOK_SIGNING_SECRET=change_me
# NOTIFICATION_PROVIDER_WEBHOOK_MAX_AGE_SECONDS=300
# NOTIFICATION_RECONCILE_LIMIT=50
# NOTIFICATION_WEBHOOK_RECONCILE_MAX_ATTEMPTS=6
# SMS_PROVIDER_ENDPOINT=https://provider.example.com/sms/send
# SMS_PROVIDER_TOKEN=provider_token
# WHATSAPP_PROVIDER_ENDPOINT=https://provider.example.com/wa/send
# WHATSAPP_PROVIDER_TOKEN=provider_token
# NOTIFICATION_ASSUME_DELIVERED=false

# --- P0-10 observability / SLO ---
# OBSERVABILITY_COLLECTOR_SECRET=change_me (fallback: CRON_SECRET / NOTIFICATION_WORKER_SECRET)
# OBSERVABILITY_AWS_REGION=eu-north-1
# OBSERVABILITY_CLOUDWATCH_NAMESPACE=Teachera/ExamPlatform
# OBSERVABILITY_DASHBOARD_NAME=teachera-p0-10-observability
# OBSERVABILITY_ALARM_PREFIX=teachera-p0-10
# OBSERVABILITY_ALARM_SNS_TOPIC_ARN=arn:aws:sns:eu-north-1:123456789012:teachera-ops-alerts
# OBS_SLO_P95_MS=1200
# OBS_SLO_P99_MS=2500
# OBS_SLO_ERROR_RATE_PCT=2
# OBS_SLO_QUEUE_DEPTH=200
# OBS_SLO_QUEUE_LAG_SECONDS=300
# OBS_SLO_WORKER_FAIL_RATE_PCT=5
# OBS_SLO_SMS_SUCCESS_RATE_PCT=85
# OBS_SLO_WA_SUCCESS_RATE_PCT=80

# --- P0-11 certified load & resilience ---
# EXAM_API_BASE_URL=https://exam-api.teachera.com.tr
# P0_11_CAMPAIGN_CODE=P0_11_CERT_2026
# P0_11_REPORT_SIGNING_KEY=long_random_secret_for_hmac
# P0_11_REPORT_SIGNER=teachera-ops
# P0_11_REPORT_OUT=guidelines/p0-11-load-resilience-report-latest.json
# P0_11_REPORT_SUMMARY_OUT=guidelines/p0-11-load-resilience-report-latest.md
