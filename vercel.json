{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/konya-ingilizce-kursu",
      "destination": "/egitimlerimiz/ingilizce/grup-programi",
      "permanent": true
    },
    {
      "source": "/konya-ingilizce-kursu/",
      "destination": "/egitimlerimiz/ingilizce/grup-programi",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
