{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/notifications/worker?limit=100&reconcile_limit=100",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/ops/observability/collect?sample_size=5&timeout_ms=4500",
      "schedule": "*/5 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/konya-ingilizce-kursu",
      "destination": "/egitimlerimiz/ingilizce/grup-programi",
      "permanent": true
    },
    {
      "source": "/konya-ingilizce-kursu/",
      "destination": "/egitimlerimiz/ingilizce/grup-programi",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
