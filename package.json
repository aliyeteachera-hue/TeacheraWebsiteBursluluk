{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build",
    "dev": "vite",
    "p0:quick": "npm run lint && npm run typecheck && npm run test",
    "p0:quick:full": "npm run p0:quick && npm run build",
    "db:migrate": "node scripts/db-migrate.mjs",
    "p0:generate-pii-key-material": "node scripts/p0-8-generate-pii-key-material.mjs",
    "p0:backfill-pii": "node scripts/p0-8-backfill-pii.mjs",
    "p0:topology:preflight": "node scripts/p0-9-topology-audit.mjs --http --aws --preflight-only",
    "p0:topology:audit": "node scripts/p0-9-topology-audit.mjs",
    "p0:topology:autodiscover": "node scripts/p0-9-autodiscover-and-audit.mjs",
    "p0:observability:preflight": "node scripts/p0-10-observability-audit.mjs --http --aws --preflight-only",
    "p0:observability:provision": "node scripts/p0-10-observability-provision.mjs",
    "p0:observability:audit": "node scripts/p0-10-observability-audit.mjs",
    "p0:observability:all": "npm run p0:observability:provision && npm run p0:observability:audit -- --http --aws",
    "p0:load-resilience:certify": "node scripts/p0-11-load-resilience-certify.mjs",
    "p0:load-resilience:verify-signature": "node scripts/p0-11-load-resilience-verify-signature.mjs",
    "p0:load-resilience:all": "npm run p0:load-resilience:certify && npm run p0:load-resilience:verify-signature",
    "panel:create-admin": "node scripts/panel-create-admin.mjs",
    "panel:generate-totp-secret": "node scripts/panel-generate-totp-secret.mjs",
    "panel:generate-totp-code": "node scripts/panel-generate-totp-code.mjs",
    "p0:go-live:package:audit": "node scripts/p0-12-go-live-package-audit.mjs",
    "p0:go-live:approve": "node scripts/p0-12-go-live-approve.mjs",
    "p0:go-live:all": "npm run p0:go-live:package:audit -- --http",
    "p0:go-live:checklist:set": "node scripts/p0-12-go-live-checklist-set.mjs",
    "p0:evidence:gate": "node scripts/p0-evidence-gate.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1007.0",
    "@aws-sdk/client-kms": "^3.1006.0",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "2.1.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "pg": "^8.16.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.13.0",
    "redis": "^4.7.1",
    "sonner": "2.0.3",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.1.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "tailwindcss": "4.1.12",
    "typescript-eslint": "^8.56.1",
    "vite": "6.3.5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
